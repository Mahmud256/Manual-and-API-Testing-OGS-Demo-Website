    {
      "name": "random product add to cart",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const products = [\r",
              "    {\r",
              "        \"productId\": \"681ccbb8def894959af74ac0\",\r",
              "        \"name\": \"Samsung Galaxy Z Fold5\",\r",
              "        \"brand\": \"Samsung\",\r",
              "        \"description\": \"Samsung Galaxy Z Fold 5 is a foldable smartphone featuring a 7.6-inch foldable Dynamic AMOLED display, Snapdragon 888 chipset, triple-camera setup, and support for S Pen stylus.\",\r",
              "        \"price\": \"179999\",\r",
              "        \"category\": \"smartphone\",\r",
              "        \"photos\": \"https://static-01.daraz.com.bd/p/f3a182339ac46bc4a5992463b26d76cf.jpg_300x0q75.webp\"\r",
              "    },\r",
              "    {\r",
              "        \"productId\": \"681ccbb8def894959af74ac5\",\r",
              "        \"name\": \"Realme GT Master Edition\",\r",
              "        \"brand\": \"Realme\",\r",
              "        \"description\": \"The Realme GT Master Edition is a stylish smartphone designed by Naoto Fukasawa. It features a Qualcomm Snapdragon 778G chipset, a 6.43-inch Super AMOLED display, a triple-camera setup with a 64MP primary sensor, and a 4300mAh battery with 65W fast charging support.\",\r",
              "        \"price\": \"39999\",\r",
              "        \"category\": \"smartphone\",\r",
              "        \"photos\": \"https://i.ibb.co/ymZK2dWB/82f187af4beef2ed8faff8dcf6570f82-jpg-720x720q80.jpg\"\r",
              "    },\r",
              "    {\r",
              "        \"productId\": \"681ccbb8def894959af74ac8\",\r",
              "        \"name\": \"iPhone 13\",\r",
              "        \"brand\": \"iPhone\",\r",
              "        \"description\": \"The iPhone 13 is Apple's mainstream smartphone featuring a 6.1-inch Super Retina XDR display, A15 Bionic chip, dual-camera system with Night mode, and up to 512GB of storage.\",\r",
              "        \"price\": \"799\",\r",
              "        \"category\": \"smartphone\",\r",
              "        \"photos\": \"data:image/jpeg;base64,\"\r",
              "    }\r",
              "];\r",
              "\r",
              "const randomIndex = Math.floor(Math.random() * products.length);\r",
              "const product = products[randomIndex];\r",
              "\r",
              "pm.variables.set(\"productId\", product.productId);\r",
              "pm.variables.set(\"name\", product.name);\r",
              "pm.variables.set(\"brand\", product.brand);\r",
              "pm.variables.set(\"category\", product.category);\r",
              "pm.variables.set(\"description\", product.description);\r",
              "pm.variables.set(\"photos\", product.photos);\r",
              "pm.variables.set(\"price\", product.price);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "console.log(\"jsonData:\", jsonData);\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Product successfully added\", function () {\r",
              "    pm.expect(jsonData.acknowledged).to.eql(true);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
