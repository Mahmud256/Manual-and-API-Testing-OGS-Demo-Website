  "item": [
    {
      "name": "OGS login testing",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "// Save to environment\r",
              "pm.environment.set(\"token\", jsonData.displayName);\r",
              "pm.environment.set(\"email\", jsonData.email);\r",
              "\r",
              "// Status check\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Email and Token check\r",
              "pm.test(\"Email and Token is correct\", function () {\r",
              "    pm.expect(jsonData.email).to.eql(pm.environment.get(\"email\"));\r",
              "    pm.expect(jsonData.displayName).to.eql(pm.environment.get(\"token\"));\r",
              "});\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"email\": \"be@gmail.com\",\r\n    \"password\": \"@A123456\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=AIzaSyCHDhFJyvCW53btSx_4t55ginqA_HbZYXY",
          "protocol": "https",
          "host": [
            "identitytoolkit",
            "googleapis",
            "com"
          ],
          "path": [
            "v1",
            "accounts:signInWithPassword"
          ],
          "query": [
            {
              "key": "key",
              "value": "AIzaSyCHDhFJyvCW53btSx_4t55ginqA_HbZYXY"
            }
          ]
        }
      },
      "response": []
    },
